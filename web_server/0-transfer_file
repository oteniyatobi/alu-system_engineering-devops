#!/usr/bin/env bash
# Transfer a file from the local client to a remote server over SSH.
# Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY

if [ "$#" -ne 4 ]; then
    echo "Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY"
    exit 1
fi

file_path="$1"
destination_ip="$2"
username="$3"
ssh_key_path="$4"

if [ ! -f "$file_path" ]; then
    echo "File not found: $file_path"
    exit 1
fi

scp -o StrictHostKeyChecking=no -i "$ssh_key_path" "$file_path" "$username@$destination_ip:~/"
