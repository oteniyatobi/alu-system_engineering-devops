#!/usr/bin/env bash
# Configures Nginx to add a custom X-Served-By header with the server hostname
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y nginx
HOSTNAME=$(hostname)
sed -i "0,/server_name _;/s|server_name _;|server_name _;\n\tadd_header X-Served-By $HOSTNAME;|" /etc/nginx/sites-available/default
service nginx restart || service nginx start
